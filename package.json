{
  "name": "effect-fundamentals-bootcamp",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "tsc --noEmit && tsc -p web/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lesson": "node --import tsx",
    "course": "vite --config web/vite.config.ts",
