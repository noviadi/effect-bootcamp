    "course:preview": "vite preview --config web/vite.config.ts"
  },
  "dependencies": {
    "dompurify": "^3.2.6",
    "effect": "^3.17.7",
    "highlight.js": "^11.11.1",
    "marked": "^15.0.12"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.5",
    "vitest": "^3.2.0"
  }
}
